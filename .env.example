# ── Backend (server/index.js) ──────────────────────────────
# Copy to .env for local dev. In production set these on the host (Render).
ADMIN_PASSWORD=change-me
PORT=4000
# Persistent storage dir (host mounts a disk here). Local: leave unset.
# DATA_DIR=/data
# Allowed frontend origin(s), comma-separated. Local: leave unset (open).
# CORS_ORIGIN=https://your-frontend.vercel.app

# ── Frontend (Vite) ────────────────────────────────────────
# Backend origin for the deployed frontend. Local: leave unset (Vite proxy handles /api).
# VITE_API_URL=https://deciops-demo-api.onrender.com
